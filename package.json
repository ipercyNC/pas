{
  "name": "pas-prototype",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "backend/.venv/bin/uvicorn app.main:app --reload --port 8000 --app-dir backend & vite",
    "typecheck": "tsc -b --pretty false",
    "lint": "npm run typecheck",
    "test:backend": "PYTHONPATH=backend backend/.venv/bin/python -m pytest backend/tests -q",
    "test:frontend": "vitest run",
    "test": "npm run test:backend && npm run test:frontend",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "verify": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^2.1.9"
  }
}
